# Email Server Configuration (Resend)
# Get this key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Supabase Configuration (Required for tracking email events)
# Copy these exact values from your backend-wa/.env file
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_key

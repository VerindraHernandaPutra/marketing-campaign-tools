# Supabase Configuration
# Found in Supabase Settings > API
SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: Use the SERVICE_ROLE SECRET (not the anon public key) for the backend worker
SUPABASE_SERVICE_KEY=your_service_role_secret

# Twilio Setup (Get from Console -> Account Info)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Twilio Number (Sandbox format: whatsapp:+14155238886)
TWILIO_PHONE_NUMBER=whatsapp:+...
